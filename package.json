{
  "name": "cheatsheet",
  "author": "chairulakmal",
  "version": "1.0.0",
  "private": true,
  "description": "Beginner-friendly developer cheatsheets built from Markdown into static HTML.",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "npm run build:css && tsx scripts/build.ts && tsx scripts/pdf.ts",
    "build:html": "npm run build:css && tsx scripts/build.ts",
    "build:css": "tailwindcss -c tailwind.config.cjs -i assets/input.css -o assets/style.css --minify",
    "build:pdf": "tsx scripts/pdf.ts",
    "clean": "rm -rf dist",
    "dev": "nodemon --watch src --watch assets --ext md,css,ts --exec \"npm run build:html\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint scripts/ src/",
    "validate": "tsx scripts/validate.ts",
    "check": "npm run typecheck && npm run lint"
  },
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^22.7.5",
    "autoprefixer": "^10.5.0",
    "chokidar": "^4.0.1",
    "esbuild": "^0.24.0",
    "eslint": "^10.5.0",
    "marked": "^14.1.3",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.15",
    "puppeteer-core": "^25.1.0",
    "shiki": "^1.22.0",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.61.1"
  }
}